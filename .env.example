# Copy to ".env.local" (gitignored) and add your key — never commit real keys.
# Get a key: Google Cloud Console → APIs & Services → Credentials
# Enable "Maps JavaScript API" + "Maps Embed API" (Street View iframe in listing modal); restrict by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=
# Reed's Home Finder: max listings per request + how many consecutive API pages to merge (deduped).
# Defaults: 100 × 8 pages — upstream may cap lower; raise ZILLOW_MAX_PAGES to 12 only if your plan allows the quota.
# VITE_ZILLOW_PAGE_LIMIT=100
# VITE_ZILLOW_MAX_PAGES=8
# Auto re-fetch the same search after N hours (long-lived tab + returning visible). Default 72 (3 days). Range 6–336.
# VITE_LISTINGS_AUTO_REFRESH_HOURS=72
# How often to check staleness while the tab is open (minutes). Default 30. Range 5–180.
# VITE_LISTINGS_STALE_CHECK_MINUTES=30
# Homes per “list” / rail page when browsing merged results (map still shows every pin). Default ≈ ZILLOW_PAGE_LIMIT. Range 12–200.
# VITE_LISTINGS_UI_PAGE_SIZE=100
# Optional: Map ID from Google Cloud (vector / custom styling). ExplorerMap passes it when set.
# VITE_GOOGLE_MAP_MAP_ID=

# --- Homes tab (Express server in /server) ---
# There is NO single public API key that mirrors “all MLS” across Zillow + Redfin + Realtor.com.
# Those sites license separate broker/MLS feeds. This stack uses a Zillow-shaped aggregator:
#   RapidAPI → app "Real-Time Zillow Data" (OpenWeb Ninja) → paste your X-RapidAPI-Key here.
# Enterprise alternatives (paid, contracts): ATTOM, CoreLogic, Bridge Interactive, local MLS RETS/RESO.
# Server loads .env then .env.local (same folder as package.json). Not a VITE_ var.
RAPIDAPI_KEY=
# Optional: override if your subscription uses a different path than /search
# ZILLOW_SEARCH_PATH=/search
# Server-side duplicate-search cache for /server microclimate homes API (ms). Default 300000 (5 min). Max 3600000.
# ZILLOW_SEARCH_CACHE_TTL_MS=300000
# PORT=3001
# Production: built SPA can call the API explicitly (dev uses Vite proxy /api → :3001)

# --- Reed's Home Finder API (backend/.env — see backend/.env.example) ---
# Use either ZILLOW_API_KEY (OpenWeb direct) or RAPIDAPI_KEY (same shapes via RapidAPI).
