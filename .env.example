# Copy to ".env.local" (gitignored) and add your key — never commit real keys.
# Get a key: Google Cloud Console → APIs & Services → Credentials
# Enable only "Maps JavaScript API" for this key; restrict by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=

# --- Homes tab (Express server in /server) ---
# RapidAPI → subscribe to "Real-Time Zillow Data" (OpenWeb Ninja). Use the X-RapidAPI-Key value.
# Server loads .env then .env.local (same folder as package.json). Not a VITE_ var.
RAPIDAPI_KEY=
# Optional: override if your subscription uses a different path than /search
# ZILLOW_SEARCH_PATH=/search
# PORT=3001
# Production: built SPA can call the API explicitly (dev uses Vite proxy /api → :3001)
# VITE_API_URL=http://localhost:3001
