# Zillow/Redfin/Realtor do not share one “master MLS” API. This backend proxies OpenWeb Ninja’s Zillow-shaped feed.
# Subscribe on RapidAPI (app host real-time-zillow-data.p.rapidapi.com) or OpenWeb direct — then paste a key below.
#
# --- Option A: OpenWeb Ninja direct (x-api-key header) ---
ZILLOW_API_KEY=
# ZILLOW_API_BASE=https://api.openwebninja.com/realtime-zillow-data

# --- Option B: Same Zillow-shaped API via RapidAPI (use when direct key fails) ---
# RAPIDAPI_KEY=
# OPENWEB_NINJA_KEY=   # alias for RAPIDAPI_KEY
# ZILLOW_RAPIDAPI_HOST=real-time-zillow-data.p.rapidapi.com

PORT=3001
